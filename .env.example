PORT=4001
BACKEND_URL=http://localhost:4001

# Polymarket Data API key (optional — app also falls back to public Polymarket Gamma API)
POLYMARKET_DATA_API_KEY=pk_live_your_key_here
# or
UCL_prediction_api=pk_live_your_key_here

# BallDontLie UCL API (https://app.balldontlie.io) — npm run import:balldontlie
BALLDONTLIE_API_KEY=your_balldontlie_api_key_here

# Groq — free tier AI for Market Analyst tab (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
