PORT=4001
BACKEND_URL=http://localhost:4001

# Polymarket Data API key (optional — app uses public Gamma API by default for live final odds)
POLYMARKET_DATA_API_KEY=pk_live_your_key_here
# Set to 1 only if you want to try polymarketdata.co before Gamma (not needed for UCL final 1X2)
# POLYMARKET_USE_DATA_API=0
# Blend weights (0–1): Polymarket share vs season model
# POLYMARKET_PREDICTION_WEIGHT=0.65
# POLYMARKET_STATS_WEIGHT=0.6
# or
UCL_prediction_api=pk_live_your_key_here

# BallDontLie UCL API (https://app.balldontlie.io) — npm run import:balldontlie
BALLDONTLIE_API_KEY=your_balldontlie_api_key_here

# Groq — free tier AI for Market Analyst tab (https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile
